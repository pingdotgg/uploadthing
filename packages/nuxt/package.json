{
  "name": "@uploadthing/nuxt",
  "version": "7.1.10",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "github:pingdotgg/uploadthing",
    "directory": "packages/nuxt"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs",
      "style": "./dist/runtime/uploadthing-tw.css"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": ["./dist/types.d.mts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "build": "nuxt-module-build build && tsc",
    "clean": "git clean -xdf .nuxt dist node_modules",
    "dev": "nuxi dev playground --port 3010",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "prepack": "bun ../../.github/replace-workspace-protocol.ts",
    "dev:prepack": "nuxt-module-build build",
    "FIXME__test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "@uploadthing/vue": "workspace:*",
    "defu": "^6.1.7",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@uploadthing/eslint-config": "workspace:*",
    "eslint": "9.25.1",
    "h3": "^1.13.0",
    "nuxt": "^4.4.2",
    "uploadthing": "workspace:*",
    "vite": "^6.3.4",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "uploadthing": "^7.2.0"
  }
}
